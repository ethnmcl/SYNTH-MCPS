{
  "name": "base44-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-grade custom MCP server for Base44 orchestration workflows",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
