{
  "name": "supabase-mcp",
  "version": "1.0.0",
  "description": "MCP server for controlled Supabase access across database, storage, vectors, auth, edge functions, and project metadata.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "discover:supabase": "tsx scripts/discover-supabase.ts",
    "print:config": "tsx scripts/print-config.ts",
    "tool": "tsx scripts/mcp-tool.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@supabase/supabase-js": "^2.55.0",
    "dotenv": "^17.2.1",
    "mime-types": "^2.1.35",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/mime-types": "^2.1.4",
    "eslint": "^9.34.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
