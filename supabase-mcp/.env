# Required secrets and core project identity
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Derived URLs (auto-derived by discover script when possible)
SUPABASE_URL=
SUPABASE_REST_URL=
SUPABASE_AUTH_URL=
SUPABASE_STORAGE_URL=
SUPABASE_FUNCTIONS_URL=
SUPABASE_MANAGEMENT_API_URL=https://api.supabase.com/v1

# MCP access control
MCP_ACCESS_LEVEL=read_only
MCP_ENABLE_DANGEROUS_TOOLS=false
MCP_AUDIT_LOG_PATH=./logs/audit.log

# Optional metadata
MCP_ACTOR=local-operator
MCP_ENABLE_DRY_RUN=false
MCP_TOOL_GROUPS=db,vector,storage,admin

# Optional adapter endpoint for edge function deploy/delete operations.
# Example expected contract: POST/DELETE ${SUPABASE_FUNCTION_DEPLOY_HOOK}/{project_ref}/{function_name}
SUPABASE_FUNCTION_DEPLOY_HOOK=
